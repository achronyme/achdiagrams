{
  "name": "@achronyme/achdiagrams",
  "version": "0.0.0",
  "description": "Programmatic SVG diagram engine with chainable type-safe API. Replaces Mermaid in @achronyme docs and powers the inspector DAG.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Achronyme",
  "homepage": "https://github.com/achronyme/achdiagrams",
  "repository": {
    "type": "git",
    "url": "https://github.com/achronyme/achdiagrams.git"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "import": "./dist/pipeline/index.js",
      "require": "./dist/pipeline/index.cjs"
    },
    "./flowchart": {
      "types": "./dist/flowchart/index.d.ts",
      "import": "./dist/flowchart/index.js",
      "require": "./dist/flowchart/index.cjs"
    },
    "./dag": {
      "types": "./dist/dag/index.d.ts",
      "import": "./dist/dag/index.js",
      "require": "./dist/dag/index.cjs"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write . && pnpm typecheck",
    "prepare": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^2.1.8",
    "fast-check": "^3.23.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "diagrams",
    "svg",
    "graph",
    "layout",
    "sugiyama",
    "flowchart",
    "sequence",
    "state",
    "dag",
    "achronyme"
  ]
}
